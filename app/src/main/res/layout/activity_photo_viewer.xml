<?xml version="1.0" encoding="utf-8"?><!--
    activity_photo_viewer.xml
    ────────────────────────────────────────────────
    개선 사항:
    ① 하단 줌 버튼(－/원본/＋) 제거 → PhotoView 핀치줌으로 충분
    ② 회전 버튼만 하단 우측에 FAB 스타일로 단독 배치
    ③ 상단 바 소폭 폴리싱 (그라데이션 처리)
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ① ViewPager2 전체 화면 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ② 상단 오버레이 바: 닫기 + 파일명 + 페이지 번호 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 닫기 -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="닫기"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FFFFFF" />

        <!-- 파일명 -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:ellipsize="middle"
            android:singleLine="true"
            android:textColor="#E0E0E0"
            android:textSize="14sp" />

        <!-- n / 전체 -->
        <TextView
            android:id="@+id/tvPhotoIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

    </LinearLayout>

    <!--
        ③ 하단 회전 버튼 (단독 FAB 스타일)
           - 줌 버튼 제거: PhotoView 핀치줌으로 충분
           - 회전만 버튼 조작이 필요 → 우측 하단 단독 배치
    -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRotate"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="@string/_90"
            app:icon="@android:drawable/ic_menu_rotate"
            app:iconSize="24dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:backgroundTint="#CC1A1A1A"
            app:iconTint="#FFFFFF"
            app:cornerRadius="26dp"
            app:strokeWidth="1dp"
            app:strokeColor="#44FFFFFF" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
