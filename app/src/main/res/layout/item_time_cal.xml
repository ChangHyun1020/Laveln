<?xml version="1.0" encoding="utf-8"?><!-- 🌊 item_time_cal.xml: Notion 요청 레이아웃 - 선석/모선명/상태 → 접안/출항/시간 → 작업량 -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface_light"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── 1행: 선석 / 모선명 / 상태배지 / 선택체크 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- 선석 배지 (예: B2) -->
            <TextView
                android:id="@+id/tvBerth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tag_background_blue"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/md_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="B2(P)" />

            <!-- 구분자 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:text="/"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- 모선명 (가장 중요 - 크고 두껍게) -->
            <TextView
                android:id="@+id/tvVesselName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/md_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="VESSEL NAME" />

            <!-- 구분자 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:text="/"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- 상태 배지 (작업/예정/접안/종료) -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="작업" />

            <!-- 선택 체크 아이콘 -->
            <ImageView
                android:id="@+id/ivCheck"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                app:tint="@color/md_primary"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="10dp"
            android:background="@color/divider_color" />

        <!-- ── 2행: 접안시간 → 출항시간 + 총시간 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- 접안시간 영역 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="접안 (ETB)"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvEtb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="26/03/13 10:00" />
            </LinearLayout>

            <!-- 화살표 -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="8dp"
                android:src="@drawable/ic_arrow_forward"
                app:tint="@color/text_secondary" />

            <!-- 출항시간 영역 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="출항 (ETD)"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvEtd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="26/03/14 02:00" />
            </LinearLayout>

            <!-- 총 근무시간 (우측 강조) -->
            <TextView
                android:id="@+id/tvTotalHours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tag_background_blue"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:textColor="@color/md_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:elevation="2dp"
                tools:text="16.0시간" />

        </LinearLayout>

        <!-- ── 3행: 작업량 (양하/선적/shft) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/work_shift"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvWorkVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="240 / 251 / 10" />

        </LinearLayout>

        <!-- 하위 호환성 유지: 숨겨진 레거시 View ID 유지 -->
        <View
            android:id="@+id/tvItemAmount"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <View
            android:id="@+id/tvFirstHalf"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <View
            android:id="@+id/tvtradeTime"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <View
            android:id="@+id/tvSecondHalf"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- tvAtc 삭제됨 (Notion 명세: 작업 완료 시간 제거) -->

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
