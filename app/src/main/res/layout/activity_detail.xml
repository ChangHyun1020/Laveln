<?xml version="1.0" encoding="utf-8"?><!--
    activity_detail.xml
    ────────────────────────────────────────────
    변경사항 (FAB 부분만 수정, 나머지 100% 동일)

    🔴 변경 전:
        android:onClick="onFabAddPhotoClick"   ← 직접 함수 호출
        android:src="@android:drawable/ic_menu_camera"

    🟢 변경 후:
        android:onClick 제거                    ← 코드에서 setOnClickListener 처리
        app:srcCompat="@android:drawable/ic_menu_add"  ← 더보기 느낌의 아이콘
-->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_light">

        <!-- ① 상단 Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="?attr/colorPrimary"
            android:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIcon="@android:drawable/ic_menu_sort_by_size"
                app:navigationIconTint="#FFFFFF"
                app:titleCentered="true">

                <TextView
                    android:id="@+id/toolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </com.google.android.material.appbar.MaterialToolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- 로딩 -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/md_primary"
            android:visibility="gone"
            android:elevation="4dp" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ① 선박 정보 카드 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E1E2E5"
                    app:cardBackgroundColor="@color/surface_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_vessel_info"
                            android:textAlignment="center"
                            android:textColor="@color/on_surface"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- 선박명 + 날짜 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvVesselName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/md_primary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:drawablePadding="8dp"
                                app:drawableStartCompat="@android:drawable/ic_menu_compass"
                                app:drawableTint="@color/md_primary" />

                            <TextView
                                android:id="@+id/tvDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginBottom="16dp" />

                        <!-- 정보 그리드 스타일 (2열 배치 권장하나 기존 구조 유지하며 보완) -->
                        <TableLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="1">

                            <!-- rows using a common style -->
                            <TableRow android:layout_marginBottom="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="@string/label_corn" />

                                <TextView
                                    android:id="@+id/tvCorn"
                                    style="@style/DetailValue" />
                            </TableRow>

                            <TableRow android:layout_marginBottom="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="@string/label_flan" />

                                <TextView
                                    android:id="@+id/tvFlan"
                                    style="@style/DetailValue" />
                            </TableRow>

                            <TableRow android:layout_marginBottom="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="@string/label_floor" />

                                <TextView
                                    android:id="@+id/tvFloor"
                                    style="@style/DetailValue" />
                            </TableRow>

                            <TableRow android:layout_marginBottom="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="@string/label_row" />

                                <TextView
                                    android:id="@+id/tvRow"
                                    style="@style/DetailValue" />
                            </TableRow>

                            <TableRow android:layout_marginBottom="8dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="@string/label_twin" />

                                <TextView
                                    android:id="@+id/tvTwin"
                                    style="@style/DetailValue" />
                            </TableRow>

                            <TableRow android:layout_marginBottom="16dp">

                                <TextView
                                    style="@style/DetailLabel"
                                    android:text="@string/label_turnbuckle" />

                                <TextView
                                    android:id="@+id/tvTurnburckle"
                                    style="@style/DetailValue" />
                            </TableRow>
                        </TableLayout>

                        <!-- Notes -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_notes"
                            android:textColor="@color/md_secondary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/note_preview_background"
                            android:lineSpacingExtra="4dp"
                            android:padding="12dp"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp"
                            android:maxLines="8" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ② 사진 섹션 헤더 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_registered_photos"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPhotoCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888888"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- 사진 없을 때 -->
                <TextView
                    android:id="@+id/tvNoPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:text="@string/no_registered_photo"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- ③ 사진 그리드 (2열) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!--
            FAB 변경사항:
            🔴 기존: android:onClick="onFabAddPhotoClick" (직접 함수 호출)
                    android:src="ic_menu_camera"
            🟢 변경: onClick 제거 → DetailActivity.kt 에서 setOnClickListener 처리
                    app:srcCompat="ic_input_add" (메뉴 느낌)
        -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:contentDescription="@string/menu_desc"
            app:srcCompat="@android:drawable/ic_menu_sort_by_size"
            app:backgroundTint="?attr/colorPrimary"
            app:tint="#FFFFFF" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_main"
        app:itemIconTint="@color/md_primary"
        app:itemTextColor="@color/text_secondary"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
